<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- コンソール出力 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        ファイル出力（日次ローリング）
        - アプリ起動ディレクトリ配下の logs/application.log に書き出す
        - 日付が変わると logs/application.yyyy-MM-dd.log にリネームされる
        - 30日分を保持し、それ以前のファイルは自動削除される
    -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/application.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!--
        Aspect のログ設定
        - INFO レベル以上をコンソールとファイルの両方に出力する
        - additivity="false" により、同じログがルートロガーに二重出力されるのを防ぐ
    -->
    <logger name="com.example.aspect" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ルートロガー: WARN 以上のみ出力（Spring 等のフレームワークログを絞り込む） -->
    <root level="WARN">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
